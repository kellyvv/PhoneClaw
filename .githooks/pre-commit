#!/usr/bin/env bash
# PhoneClaw pre-commit hook — harness 守门
#
# 当 staged 文件触碰到 agent 框架/skill/prompt/router 时, 自动跑 CLI harness
# **两个模型都跑 (E2B + E4B)** — 用户部署默认只有 E2B, E4B-only 验证等于没验证.
# 不绿拒绝 commit。可用 `git commit --no-verify` 跳过 (慎用)。
#
# 安装: git config core.hooksPath .githooks
# 跳过单次: PHONECLAW_SKIP_HARNESS=1 git commit ...

set -e

# 快速出口: 手动跳过
if [[ -n "${PHONECLAW_SKIP_HARNESS:-}" ]]; then
    echo "[pre-commit] PHONECLAW_SKIP_HARNESS set — harness 跳过"
    exit 0
fi

# 守门的路径: 这些目录的任何改动都触发 harness
GUARDED_PATHS=(
    "Agent/"
    "LLM/"
    "Skills/Library/"
    "Tools/"
    "PhoneClawCLI/Sources/"
    "PhoneClawCLI/Scenarios/"
)

STAGED=$(git diff --cached --name-only --diff-filter=ACMR)

# 没有相关改动, 不跑
MATCHED=""
for path in "${GUARDED_PATHS[@]}"; do
    if echo "$STAGED" | grep -q "^${path}"; then
        MATCHED+="$path "
    fi
done

if [[ -z "$MATCHED" ]]; then
    echo "[pre-commit] 没有 agent 相关改动, harness 跳过"
    exit 0
fi

echo "[pre-commit] 触发 harness (守门路径: $MATCHED)"

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT/PhoneClawCLI"

# 跑两个模型 — E2B 是默认部署模型, E4B 是升级选项, 任何一个红就拒绝
FAILED_MODELS=()
for M in e2b e4b; do
    LOG="/tmp/phoneclaw-precommit-${M}.log"
    echo "[pre-commit] 跑 ${M} ..."
    if ! ./run.sh test "${M}" > "${LOG}" 2>&1; then
        echo "❌ ${M} harness 运行失败 (build 挂了?):"
        tail -20 "${LOG}"
        FAILED_MODELS+=("${M}")
        continue
    fi
    if ! grep -q "ALL GREEN" "${LOG}"; then
        echo "❌ ${M} harness 报红:"
        grep -E "✗ FAIL|conversation:|routing eval" "${LOG}"
        FAILED_MODELS+=("${M}")
    else
        echo "[pre-commit] ✅ ${M} 全绿"
    fi
done

if [[ ${#FAILED_MODELS[@]} -gt 0 ]]; then
    echo ""
    echo "❌ 以下模型失败: ${FAILED_MODELS[*]}"
    echo "日志: /tmp/phoneclaw-precommit-{e2b,e4b}.log"
    echo "紧急跳过: PHONECLAW_SKIP_HARNESS=1 git commit ..."
    exit 1
fi

echo "[pre-commit] ✅ E2B + E4B 全绿, commit 放行"
exit 0
